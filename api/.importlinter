; 육각형 아키텍처 계층 계약(0단계). 코드 이동 없이 "지금 지켜지는 경계"를 고정한다.
; 의존성 방향은 항상 안쪽(하위 계층)으로만 흐른다: routers → services → db.
; 신규 위반(예: 서비스가 라우터를 import, worker 가 라우터에 의존)을 githook/CI 에서 차단한다.

[importlinter]
; app·reporter·financial_ontology 을 함께 root 로 둔다 — external 이 아닌 internal 로 그래프에 올려야
; 서브모듈/패키지를 forbidden 대상으로 지정할 수 있다(external 서브패키지는 forbidden 불가).
; 공유 커널 경계(app→CLI전용 금지)·LLM·온톨로지 포트 경계를 계약으로 강제하기 위함.
root_packages =
    app
    reporter
    financial_ontology
; domain·ports 가 외부 IO 패키지를 import 하지 않는지 검사하려면 외부 패키지도 그래프에 포함.
include_external_packages = True

[importlinter:contract:layers]
name = 계층 방향 (routers → services → adapters → db)
type = layers
layers =
    app.routers
    app.services
    app.adapters
    app.db
; main(조립 루트)·scheduler·tui(진입 어댑터)는 여러 계층을 조합하므로 계층에 넣지 않는다.
; 대신 아래 독립성/금지 계약으로 역방향 오염만 막는다.

[importlinter:contract:domain-leaf]
name = domain 은 순수 코어(app 내부 의존 0)
type = forbidden
source_modules =
    app.domain
forbidden_modules =
    app.config
    app.schemas
    app.db
    app.services
    app.routers
    app.main
    app.scheduler
    app.tui
    app.adapters
    app.ports

[importlinter:contract:ports-leaf]
name = ports 는 인터페이스 리프(구현·상위계층 의존 0)
type = forbidden
source_modules =
    app.ports
forbidden_modules =
    app.services
    app.routers
    app.adapters
    app.main
    app.scheduler
    app.tui
; db.models 는 TYPE_CHECKING(런타임 미import) 타입 힌트로만 참조하므로 금지 목록에서 제외한다.

[importlinter:contract:domain-no-external-io]
name = domain·ports 는 외부 IO 패키지(reporter)를 모른다
type = forbidden
source_modules =
    app.domain
    app.ports
forbidden_modules =
    reporter
allow_indirect_imports = true

[importlinter:contract:entrypoints-not-imported]
name = 진입점(main·scheduler·tui)은 아무도 import 하지 않는다
type = forbidden
source_modules =
    app.domain
    app.ports
    app.db
    app.adapters
    app.services
    app.routers
forbidden_modules =
    app.main
    app.scheduler
    app.tui

[importlinter:contract:db-leaf]
name = db 는 상위 계층을 모른다
type = forbidden
source_modules =
    app.db
forbidden_modules =
    app.adapters
    app.services
    app.routers
    app.schemas

[importlinter:contract:config-schemas-leaf]
name = config·schemas 는 순수 리프(앱 내부 의존 없음)
type = forbidden
source_modules =
    app.config
    app.schemas
forbidden_modules =
    app.db
    app.services
    app.routers

[importlinter:contract:driving-adapters]
name = worker·tui(진입 어댑터)는 라우터를 모른다
type = forbidden
source_modules =
    app.scheduler
    app.tui
forbidden_modules =
    app.routers

[importlinter:contract:routers-no-orm]
name = 라우터는 ORM(db.models)에 직접 접근하지 않는다(데이터 접근은 services 경유)
type = forbidden
source_modules =
    app.routers
forbidden_modules =
    app.db.models
; 직접 import 만 금지한다(services→db.models 경유 간접 체인은 정상이므로 허용).
allow_indirect_imports = true
; db.session(get_session DI)·db.session.SessionLocal 은 프레임워크 배선이라 허용 —
; db.models(엔티티·쿼리)만 금지해 라우터가 응용 계층을 우회하지 못하게 한다.

[importlinter:contract:app-no-cli-only]
name = app 은 reporter 의 CLI 전용(발송 파이프라인) 모듈을 모른다 — 공유 커널만 사용
type = forbidden
source_modules =
    app
forbidden_modules =
    reporter.cli
    reporter.pipeline
    reporter.afternoon
    reporter.telegram
    reporter.forum
    reporter.shortener
    reporter.archive
    reporter.config
    reporter.grouping
    reporter.selector
; app 이 reporter 에서 쓰는 것은 공유 커널(models·market·sector_etf·fallback·ollama_client·
; crawler·pdf·news·judal·us_market·analyzer·article)로 한정한다. 텔레그램 발송 CLI 전용 모듈을
; app 이 직접 부르면 두 제품이 결합되므로 차단(docs/shared-kernel.md). allow_indirect 로 직접만 금지.
allow_indirect_imports = true

[importlinter:contract:llm-behind-port]
name = LLM(reporter.ollama_client)은 adapters.llm 뒤에만 — 서비스·라우터는 LLMPort 경유
type = forbidden
source_modules =
    app.services
    app.routers
    app.domain
    app.ports
forbidden_modules =
    reporter.ollama_client
; 유일한 구현(adapters/llm)만 reporter.ollama_client 직접 참조, 나머지는 app.ports.llm(LLMPort)에
; 의존. root_packages 로 reporter 를 internal 화해 이제 이 서브모듈 경계를 계약으로 강제할 수 있다
; (이전엔 external 서브패키지라 불가해 코드 격리로만 지켰음). allow_indirect 로 직접 import 만 금지.
allow_indirect_imports = true

[importlinter:contract:ontology-behind-port]
name = 온톨로지(financial_ontology)은 adapters.financial_ontology 뒤에만 — 서비스·라우터·도메인·포트는 OntologyPort 경유
type = forbidden
source_modules =
    app.services
    app.routers
    app.domain
    app.ports
forbidden_modules =
    financial_ontology
; 유일한 구현(adapters/financial_ontology)만 financial_ontology 패키지 직접 참조, 나머지는
; app.ports.financial_ontology(OntologyPort)에 의존. 2차-A 의 순수 패키지를 2차-B 에서 포트 뒤에 캡슐화.
; adapters 안에서만 패키지 import 허용, services 이하는 포트 경유. allow_indirect 로 직접 import 만 금지.
allow_indirect_imports = true
