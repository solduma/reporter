# KIS(한국투자증권 OpenAPI) — 차트 폴백·실시간 시세. 미설정 시 네이버만 사용(실시간 비활성).
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# 딥다이브 웹 리서치 — 네이버 검색 API(블로그·뉴스, 일 25,000회 무료): developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
