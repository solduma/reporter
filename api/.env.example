POSTGRES_URL=
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
OLLAMA_HOST=
OLLAMA_API_KEY=
SUMMARY_MODEL=
INSIGHT_MODEL=
# 후반 단계에서 필요 (DART 공시 / 관세청 무역통계 / KRX 상장주식수)
DART_API_KEY=
# DART 일일한도(2만) 초과 시 폴오버할 백업 키(다른 계정). 비우면 폴오버 없음.
DART_API_KEY_BACKUP=
CUSTOMS_API_KEY=
# KRX Open API — 재무·보고서 백필의 상장주식수(EV/EBITDA·PER 역산). 없으면 해당 계산 스킵.
KRX_API=
# 경제 캘린더 — FRED(미국 매크로 발표일·실적치), 무료 키: fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# 무위험금리 — 한국은행 ECOS(국고채 3년/10년, DCF 할인율·영구성장), 무료 키: ecos.bok.or.kr/api
# 미설정 시 DCF 는 고정상수(3.2%) 폴백. 신청 즉시 자동 발급.
ECOS_API_KEY=
# KIS(한국투자증권 OpenAPI) — 차트 폴백·실시간 시세. 미설정 시 네이버만 사용(실시간 비활성).
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# 딥다이브 웹 리서치 — 네이버 검색 API(블로그·뉴스, 일 25,000회 무료): developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
