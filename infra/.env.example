# infra/docker-compose.yml 용 변수. 실제 값은 infra/.env (gitignore) 에 둔다.
# docker compose --env-file .env 로 로드되어 worker environment 의 ${VAR} 치환에 쓰인다.
# worker(스케줄러)는 재무·보고서·캘린더·딥다이브 배치를 돌리므로 그 배치가 쓰는 외부 키가 여기 있어야 한다.

# 인프라(postgres/minio 자격증명)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# LLM — reporter-worker(스케줄러)가 GLM 호출에 사용
OLLAMA_HOST=
OLLAMA_API_KEY=
SUMMARY_MODEL=
INSIGHT_MODEL=

# 외부 데이터 소스 키 — worker 배치가 호출(없으면 해당 배치 조용히 스킵/폴백)
# DART 공시·KRX 상장주식수: 재무·보고서·EV/EBITDA 백필. FRED: 경제 캘린더(미국 매크로).
DART_API_KEY=
KRX_API=
FRED_API_KEY=
# 딥다이브 웹 리서치 — 네이버 검색 API(블로그·뉴스). worker 가 딥다이브 큐를 실행하므로 여기 필요.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
