# 증권 리포트 텔레그램 브리핑 크론 예시 (macOS crontab)
# 등록: crontab -e  (macOS 보안 UI 승인은 사람이 직접 해야 함)
# PROJECT / PY 경로를 자기 환경에 맞게 수정.

PROJECT=/Users/you/workspace/reporter
PY=/Users/you/workspace/reporter/.venv/bin/python

# 07:00 — 미국증시 마감 + 간밤 뉴스 종합 (월~금)
0 7 * * 1-5 cd $PROJECT && $PY -m reporter.cli --premarket >> logs/cron.log 2>&1

# 09:00 — 전날 브리핑 로그 초기화
0 9 * * 1-5 cd $PROJECT && $PY -m reporter.cli --reset-log

# 09:30 — 종목분석·산업분석 개별(종목/산업 단위 종합)
30 9 * * 1-5 cd $PROJECT && $PY -m reporter.cli --per-entity >> logs/cron.log 2>&1

# 10:00 — 시황·투자 종합 (각각 장문 1건)
0 10 * * 1-5 cd $PROJECT && $PY -m reporter.cli --digest market_info >> logs/cron.log 2>&1
0 10 * * 1-5 cd $PROJECT && $PY -m reporter.cli --digest invest >> logs/cron.log 2>&1

# 10:30 — 경제 종합 / 11:00 — 채권 종합
30 10 * * 1-5 cd $PROJECT && $PY -m reporter.cli --digest economy >> logs/cron.log 2>&1
0 11 * * 1-5 cd $PROJECT && $PY -m reporter.cli --digest debenture >> logs/cron.log 2>&1

# 14:00 — 오후 능동 리서치
0 14 * * 1-5 cd $PROJECT && $PY -m reporter.cli --afternoon >> logs/cron.log 2>&1

# 17:00 — 마감 시황 종합
0 17 * * 1-5 cd $PROJECT && $PY -m reporter.cli --closing >> logs/cron.log 2>&1

# 09~16시 매시 정각 — 장중 시장 뉴스 종합 (cron 은 range 지원)
0 9-16 * * 1-5 cd $PROJECT && $PY -m reporter.cli --news >> logs/cron.log 2>&1
