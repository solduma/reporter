# APP_ENV=dev (default) or prod → loads .env.{APP_ENV}
APP_ENV=dev

# Ollama Cloud — https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
# 개별 요약(1차) / 종합 분석(2차)에 쓸 모델 태그 (Ollama Cloud 는 :cloud 접미사 사용)
OLLAMA_SUMMARY_MODEL=glm-5.2:cloud
OLLAMA_INSIGHT_MODEL=glm-5.2:cloud

# Telegram — @BotFather 로 봇 생성 후 발급
TELEGRAM_BOT_TOKEN=
# 발송 대상 chat_id. 토픽 기능을 쓰려면 '포럼 모드 ON' 슈퍼그룹의 id 여야 한다(채널은 토픽 불가).
TELEGRAM_CHAT_ID=
# 종목/산업 리포트·장중뉴스를 일자별 포럼 토픽에 누적(1/true/yes). 봇에 manage_topics 관리자 권한 필요.
TELEGRAM_USE_TOPICS=

DART_API_KEY=

CUSTOMS_API_KEY=

# 차트 폴백(네이버 실패 시 국내 봉): KIS 한국투자증권 OpenAPI
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# KRX 정보데이터시스템 OpenAPI AUTH_KEY (보조 폴백)
KRX_API=